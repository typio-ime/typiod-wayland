# Typio Wayland frontend configuration example
#
# Location: $XDG_CONFIG_HOME/typio/wayland.toml
#          (defaults to ~/.config/typio/wayland.toml)
#
# This file owns Panel styling for the Wayland frontend. Framework policy,
# shortcuts, voice runtime, and per-engine settings live in core.toml next
# to it. Last-used engine selection is runtime state, not config.
#
# For the full reference of every key, see docs/reference/configuration.md.

[display]
# Theme: "auto" (follow desktop), "light", or "dark"  (default: "auto")
panel_theme = "auto"

# Candidate layout: "horizontal" or "vertical"  (default: "vertical")
candidate_layout = "vertical"

# Panel font size in points, range 6–72  (default: 11)
font_size = 11

# Font family for the Panel  (default: "Sans")
# font_family = "Noto Sans CJK SC"

# Show engine mode label (e.g. "中" / "A") in the Panel  (default: false)
# panel_mode_indicator = false

# Try a no-op text-input commit before falling back when status UI needs a
# cursor anchor but the compositor has not sent one yet. This improves Chrome
# and Firefox indicator/voice placement when they update caret rectangles only
# after input-method commits. (default: true)
# anchor_probe = true
# anchor_probe_timeout_ms = 150

# ── Custom colour schemas ─────────────────────────────────────────────
# Define per-channel overrides for the light and/or dark variants.
# Custom values take priority over the built-in palette for that variant.
# The active variant is chosen by panel_theme (or desktop detection for "auto").
# Use 6-digit hex (#rrggbb) or 8-digit hex (#rrggbbaa) with alpha.
# Omit any key to keep the built-in default for that channel.

# [display.colors.light]
# background     = "#f8f9fa"
# border         = "#ced4da"
# text           = "#212529"
# muted          = "#868e96"   # candidate index numbers and mode label
# preedit        = "#495057"
# selection      = "#339af0f5"
# selection_text = "#ffffff"

# [display.colors.dark]
# background     = "#141414"
# border         = "#2a2a2a"
# text           = "#e8e8e8"
# muted          = "#666666"
# preedit        = "#aaaaaa"
# selection      = "#1971c2f5"
# selection_text = "#ffffff"
