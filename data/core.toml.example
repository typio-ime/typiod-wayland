# Typio framework configuration example
#
# Location: $XDG_CONFIG_HOME/typio/core.toml
#          (defaults to ~/.config/typio/core.toml)
#
# This file owns persistent framework policy, shortcuts, notifications,
# voice runtime, and per-engine settings. Last-used engine selection is
# runtime state under $XDG_STATE_HOME/typio, so an installation may start
# with no configured engine and resume the last active one later.
#
# Frontend styling (Panel theme, fonts, colours) lives in platform.toml next
# to this file.
#
# For the full reference of every key, see docs/reference/configuration.md.

[keyboard]
# Remember and restore the keyboard engine and engine mode per application.
# per_app_preferences = true

# Override the keyboard engine to activate on startup. When omitted,
# the last-used engine is resumed from state; if no state exists the
# first available keyboard engine is auto-selected.
# keyboard.engine = "rime"

# Installed engines that should NOT be loaded.  Comma-separated names.
# Disabled engines are skipped entirely (no dlopen, no memory use).
# keyboard.disabled = "mozc"
# voice.disabled = "whisper"

# ── Engine routing (consumed by typio-linux) ───────────────────────
# These keys change how the Wayland frontend routes keys when the basic
# engine is active.  They are NOT owned by the engine plugin itself.

[engines.basic]
# "forward" sends printable keys through virtual keyboard forwarding.
# "commit" lets the basic engine commit printable text directly.
# printable_key_mode = "forward"

# Enable compose sequences for accented characters in the basic engine.
# When enabled: ' + a → á, ` + e → è, ~ + n → ñ, " + u → ü, etc.
# Default: false
# compose = true

# ── Engine-owned sections ────────────────────────────────────────────
# Each engine plugin registers its own `engines.<name>.*` schema.  The
# host does not interpret these keys; they are passed to the engine via
# the engine ABI.  Consult the plugin's documentation for authoritative
# defaults.

[engines.rime]
# shared_data_dir = "/usr/share/rime-data"
# full_check = false

[engines.mozc]
# server_path = "/usr/lib/mozc/mozc_server"

# ── Voice input ──────────────────────────────────────────────────────
# voice.engine selects which voice backend to activate on startup.
# It must match the file name prefix: libtypio_engine_<name>.so.
# When omitted or the named engine is not installed, the first available
# voice engine is auto-selected.
# voice.engine = "whisper"

# Voice engine plugin settings (illustrative):
#   - whisper:    model is ggml model name (base, small, medium, large)
#                 place model at ~/.local/share/typio/whisper/ggml-<model>.bin
#   - sherpa-onnx: model is the directory name under ~/.local/share/typio/sherpa-onnx/
#                  supports transducer (Zipformer), paraformer, whisper ONNX,
#                  nemo-ctc, SenseVoice

# [engines.whisper]
# language = "zh"
# model = "base"

# [engines.sherpa-onnx]
# language = "auto"
# model = "sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17"

# ── Notifications ────────────────────────────────────────────────────
# Consumed by typio-linux.  Controls startup health notifications and
# runtime toast behaviour.

# [notifications]
# enable = true
# startup_checks = true
# runtime = true
# voice = true
# cooldown_ms = 5000

# ── Keyboard shortcuts ───────────────────────────────────────────────
# Parsed by libtypio.  Values are shortcut strings such as Ctrl+Shift
# or Super+v.

[shortcuts]
# switch_keyboard_engine = "Ctrl+Shift"
# exit = "Ctrl+Shift+Escape"
# voice_ptt = "Super+v"
